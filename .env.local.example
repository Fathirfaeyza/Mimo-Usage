# Dashboard authentication
# Set a password to enable login protection. Leave empty to disable auth.
DASHBOARD_PASSWORD=""

# Required for session token signing.
# Generate a random secret: openssl rand -base64 32
AUTH_SECRET=""

# Vercel KV (for production storage)
# These are automatically set when you link a KV store in Vercel dashboard.
# For local development, you can use Vercel KV locally or fall back to file-based storage.
# KV_REST_API_URL=""
# KV_REST_API_TOKEN=""
